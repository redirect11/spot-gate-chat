rules_version = '2';

// Public, ephemeral mIRC-style chat for the 67th meetup.
// No private data is stored. Identity is a self-assigned nickname + a
// client-generated (or anonymous-auth) uid. Rules below keep things bounded:
// messages are immutable once written, channels can't be deleted, and the
// shape of every write is validated. If Anonymous Auth gets enabled in the
// Firebase console these same rules keep working — tighten them then by
// requiring `request.auth != null`.
service cloud.firestore {
  match /databases/{database}/documents {

    function validChannel() {
      return request.resource.data.name is string
        && request.resource.data.name.size() <= 64
        && request.resource.data.topic is string
        && request.resource.data.topic.size() <= 200;
    }

    match /channels/{channelId} {
      allow read: if true;
      allow create, update: if validChannel();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if true;
        allow create: if request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() <= 40
          // clients can't post as a bot (userId "bot:*") — only the
          // server-side engine (admin SDK) bypasses these rules
          && !(request.resource.data.userId is string
               && request.resource.data.userId.matches('bot:.*'));
        // messages are append-only — no edits or deletes from clients
        allow update, delete: if false;
      }

      match /members/{uid} {
        allow read: if true;
        // presence docs: bounded size; clients may NOT grant themselves op —
        // op is only set by the admin Cloud Functions (which bypass rules).
        allow write: if request.resource.data == null
          || (
            request.resource.data.nickname is string
            && request.resource.data.nickname.size() <= 40
            && (
              request.resource.data.isOp == false
              || (resource != null
                  && request.resource.data.isOp == resource.data.isOp)
            )
            && (
              !('voice' in request.resource.data)
              || request.resource.data.voice == false
              || (resource != null && 'voice' in resource.data
                  && request.resource.data.voice == resource.data.voice)
            )
          );
      }

      // Mute list — managed only by the admin Cloud Function.
      match /mutes/{uid} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Bot registry — public read (the UI may list bots), but writes go only
    // through the admin SDK (scripts/deploy-bots.mjs), which bypasses rules.
    match /bots/{botId} {
      allow read: if true;
      allow write: if false;
    }

    // Ban list — managed only by the admin Cloud Function (admin SDK bypasses
    // rules). Not readable/writable by clients.
    match /bans/{id} {
      allow read, write: if false;
    }

    // IP map (uid -> salted IP hash) and IP bans — only the Cloud Functions
    // touch these. Never exposed to clients.
    match /ipmap/{uid} {
      allow read, write: if false;
    }
    match /ipbans/{id} {
      allow read, write: if false;
    }

    // Private messages (DMs). Note: without authenticated identities these are
    // not cryptographically private — they're validated but readable by anyone
    // who knows the conversation id. Casual privacy only.
    match /dms/{convoId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(
        ['participants', 'nicks', 'updatedAt', 'lastFrom', 'lastText']
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if true;
        allow create: if request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.fromNick is string
          && request.resource.data.fromNick.size() <= 40;
        allow update, delete: if false;
      }
    }
  }
}
